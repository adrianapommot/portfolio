#!/usr/bin/env bash
# Guard de deploy: bloqueia travessões em texto renderizado e refs de imagem quebradas.
# Ativado via: git config core.hooksPath .githooks
# Checa só os HTML que estão STAGED neste commit.
set -u
ROOT="$(git rev-parse --show-toplevel)"
STAGED=()
while IFS= read -r line; do
  [ -n "$line" ] && STAGED+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACM -- '*.html' | grep -vE '^_archive/')
[ "${#STAGED[@]}" -eq 0 ] && exit 0
exec bash "$ROOT/tools/deploy-check.sh" "${STAGED[@]}"
